# Copy this file to `.env` and adjust. The real `.env` is gitignored.
#
# Database (default: SQLite file in project root)
# DATABASE_URL=sqlite:///./usecase_factory.db
#
# Optional: Postgres example
# DATABASE_URL=postgresql://user:password@localhost:5432/detection_rules
#
# App environment (dev|prod). In prod, app shows security posture findings.
# APP_ENV=dev
#
# Optional webhook signing secret env vars (set in deployment, not in git):
# DRF_WEBHOOK_SECRET_SECURITY=change-me
